from fastapi import APIRouter, Body, Depends, HTTPException, Query
from sqlalchemy.orm import Session
from app.ledger.validator_config import QUORUM_SIZE

from app.ledger.sync_state import get_consensus_value

from app.db.ledger_database import get_ledger_db
from app.ledger.block_sync import import_raw_block, sync_missing_blocks_once
from app.ledger.models import (
    LedgerBlock,
    LedgerClaim,
    LedgerCommitSignature,
    LedgerProposal,
    OwnershipIndex,
    PendingClaim,
)

from app.ledger.schemas import (
    ForwardClaimRequest,
    ForwardClaimResponse,
    LedgerProposalRequest,
    LedgerProposalResponse,
    LedgerVoteRequest,
    LedgerVoteResponse,
)

from app.ledger.validator_config import THIS_RELAY_DOMAIN

router = APIRouter(prefix="/ledger", tags=["ledger-validator"])


@router.get("/blocks/head")
def get_ledger_head(db: Session = Depends(get_ledger_db)):
    head = db.query(LedgerBlock).order_by(LedgerBlock.block_index.desc()).first()
    if head is None:
        return {
            "relayDomain": THIS_RELAY_DOMAIN,
            "currentBlockIndex": 0,
            "currentBlockHash": "GENESIS",
        }

    return {
        "relayDomain": THIS_RELAY_DOMAIN,
        "currentBlockIndex": head.block_index,
        "currentBlockHash": head.block_hash,
    }


@router.get("/blocks/{block_index}")
def get_block(block_index: int, db: Session = Depends(get_ledger_db)):
    block = db.query(LedgerBlock).filter(LedgerBlock.block_index == block_index).first()
    if block is None:
        raise HTTPException(status_code=404, detail="block not found")
    return {
        "blockIndex": block.block_index,
        "rawBlock": block.raw_block_json,
    }


@router.get("/blocks")
def get_block_range(
    start: int = Query(..., ge=1),
    end: int = Query(..., ge=1),
    db: Session = Depends(get_ledger_db),
):
    if end < start:
        raise HTTPException(status_code=400, detail="invalid range")

    blocks = (
        db.query(LedgerBlock)
        .filter(LedgerBlock.block_index >= start, LedgerBlock.block_index <= end)
        .order_by(LedgerBlock.block_index.asc())
        .all()
    )

    return {
        "blocks": [
            {
                "blockIndex": block.block_index,
                "rawBlock": block.raw_block_json,
            }
            for block in blocks
        ]
    }


@router.get("/pending-claims")
def get_pending_claims(db: Session = Depends(get_ledger_db)):
    claims = (
        db.query(PendingClaim)
        .filter(PendingClaim.status == "pending_consensus")
        .order_by(PendingClaim.received_at.asc())
        .all()
    )
    return {
        "pendingClaims": [
            {
                "blankID": row.blank_id,
                "relayDomain": row.relay_domain,
                "identityKeyBase64": row.identity_key_base64,
                "identitySigningPublicKeyBase64": row.identity_signing_public_key_base64,
                "ownershipSignatureBase64": row.ownership_signature_base64,
                "claimedAt": row.claimed_at,
                "nonce": row.nonce,
                "clientClaimHash": row.client_claim_hash,
                "relaySignatureBase64": row.relay_signature_base64,
                "receivedAt": row.received_at,
                "status": row.status,
            }
            for row in claims
        ]
    }


@router.post("/blocks/import")
def import_block(rawBlock: str = Body(..., embed=True), db: Session = Depends(get_ledger_db)):
    import_raw_block(db, rawBlock)
    return {"success": True, "message": "block imported"}


@router.post("/sync/run")
def run_manual_sync():
    sync_missing_blocks_once()
    return {"success": True, "message": "sync completed"}


@router.get("/ownership-index")
def get_ownership_index(db: Session = Depends(get_ledger_db)):
    rows = db.query(OwnershipIndex).order_by(OwnershipIndex.blank_id.asc()).all()
    return {
        "ownershipIndex": [
            {
                "blankID": row.blank_id,
                "blockIndex": row.block_index,
                "relayDomain": row.relay_domain,
                "identityKeyBase64": row.identity_key_base64,
                "identitySigningPublicKeyBase64": row.identity_signing_public_key_base64,
                "ownershipSignatureBase64": row.ownership_signature_base64,
                "claimedAt": row.claimed_at,
                "clientClaimHash": row.client_claim_hash,
            }
            for row in rows
        ]
    }


@router.get("/committed-claims")
def get_committed_claims(db: Session = Depends(get_ledger_db)):
    rows = (
        db.query(LedgerClaim)
        .filter(LedgerClaim.claim_status == "committed")
        .order_by(LedgerClaim.block_index.asc(), LedgerClaim.id.asc())
        .all()
    )
    return {
        "committedClaims": [
            {
                "blankID": row.blank_id,
                "blockIndex": row.block_index,
                "relayDomain": row.relay_domain,
                "identityKeyBase64": row.identity_key_base64,
                "identitySigningPublicKeyBase64": row.identity_signing_public_key_base64,
                "ownershipSignatureBase64": row.ownership_signature_base64,
                "claimedAt": row.claimed_at,
                "nonce": row.nonce,
                "clientClaimHash": row.client_claim_hash,
                "claimStatus": row.claim_status,
            }
            for row in rows
        ]
    }


@router.get("/commit-signatures")
def get_commit_signatures(db: Session = Depends(get_ledger_db)):
    rows = (
        db.query(LedgerCommitSignature)
        .order_by(LedgerCommitSignature.block_index.asc(), LedgerCommitSignature.id.asc())
        .all()
    )
    return {
        "commitSignatures": [
            {
                "blockIndex": row.block_index,
                "relayDomain": row.relay_domain,
                "signatureBase64": row.signature_base64,
            }
            for row in rows
        ]
    }
@router.post("/votes", response_model=LedgerVoteResponse)
def submit_vote(payload: LedgerVoteRequest, db: Session = Depends(get_ledger_db)):
    existing = (
        db.query(LedgerCommitSignature)
        .filter(
            LedgerCommitSignature.block_index == payload.blockIndex,
            LedgerCommitSignature.relay_domain == payload.relayDomain,
        )
        .first()
    )
    if existing is None:
        db.add(
            LedgerCommitSignature(
                block_index=payload.blockIndex,
                relay_domain=payload.relayDomain,
                signature_base64=payload.signatureBase64,
            )
        )
        db.commit()

    return {"success": True, "message": "vote recorded"}


@router.post("/claims/forward", response_model=ForwardClaimResponse)
def forward_claim(payload: ForwardClaimRequest, db: Session = Depends(get_ledger_db)):
    existing = (
        db.query(PendingClaim)
        .filter(PendingClaim.client_claim_hash == "")
        .first()
    )

    from app.ledger.schemas import build_claim_hash
    client_claim_hash = build_claim_hash(
        network_id="blankchat-mainnet-v1",
        blank_id=payload.blankID,
        relay_domain=payload.relayDomain,
        identity_key_base64=payload.identityKeyBase64,
        identity_signing_public_key_base64=payload.identitySigningPublicKeyBase64,
        ownership_signature_base64=payload.ownershipSignatureBase64,
        claimed_at=payload.claimedAt,
        nonce=payload.nonce,
    )

    existing = (
        db.query(PendingClaim)
        .filter(PendingClaim.client_claim_hash == client_claim_hash)
        .first()
    )
    if existing is None:
        db.add(
            PendingClaim(
                blank_id=payload.blankID,
                relay_domain=payload.relayDomain,
                identity_key_base64=payload.identityKeyBase64,
                identity_signing_public_key_base64=payload.identitySigningPublicKeyBase64,
                ownership_signature_base64=payload.ownershipSignatureBase64,
                claimed_at=payload.claimedAt,
                nonce=payload.nonce,
                client_claim_hash=client_claim_hash,
                relay_signature_base64=payload.relaySignatureBase64,
                received_at=payload.claimedAt,
                status="pending_consensus",
            )
        )
        db.commit()

    return {"success": True, "message": "claim forwarded"}

@router.get("/votes/{block_index}")
def get_votes_for_block(block_index: int, db: Session = Depends(get_ledger_db)):
    rows = (
        db.query(LedgerCommitSignature)
        .filter(LedgerCommitSignature.block_index == block_index)
        .order_by(LedgerCommitSignature.id.asc())
        .all()
    )
    return {
        "blockIndex": block_index,
        "votes": [
            {
                "relayDomain": row.relay_domain,
                "signatureBase64": row.signature_base64,
            }
            for row in rows
        ],
        "voteCount": len(rows),
        "quorumRequired": QUORUM_SIZE,
        "quorumReached": len(rows) >= QUORUM_SIZE,
    }

@router.post("/proposals", response_model=LedgerProposalResponse)
def submit_proposal(payload: LedgerProposalRequest, db: Session = Depends(get_ledger_db)):
    existing = (
        db.query(LedgerProposal)
        .filter(LedgerProposal.proposal_hash == payload.proposalHash)
        .first()
    )
    if existing is None:
        db.add(
            LedgerProposal(
                round_number=payload.roundNumber,
                proposer_relay_domain=payload.proposerRelayDomain,
                proposal_hash=payload.proposalHash,
                block_index=payload.blockIndex,
                raw_block_json=payload.rawBlock,
                status="proposed",
            )
        )
        db.commit()

    return {"success": True, "message": "proposal recorded"}


@router.get("/proposals")
def get_proposals(db: Session = Depends(get_ledger_db)):
    rows = (
        db.query(LedgerProposal)
        .order_by(LedgerProposal.round_number.asc(), LedgerProposal.id.asc())
        .all()
    )
    return {
        "proposals": [
            {
                "roundNumber": row.round_number,
                "proposerRelayDomain": row.proposer_relay_domain,
                "proposalHash": row.proposal_hash,
                "blockIndex": row.block_index,
                "status": row.status,
            }
            for row in rows
        ]
    }

@router.get("/network-mode")
def get_network_mode():
    from app.ledger.validator_config import (
        IS_MULTI_RELAY_MODE,
        QUORUM_SIZE,
        THIS_RELAY_DOMAIN,
        VALIDATOR_PEERS,
    )
    return {
        "thisRelayDomain": THIS_RELAY_DOMAIN,
        "multiRelayMode": IS_MULTI_RELAY_MODE,
        "quorumRequired": QUORUM_SIZE,
        "peerRelays": VALIDATOR_PEERS,
    }


