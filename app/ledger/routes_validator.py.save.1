@router.get("/admission-status", response_model=RelayAdmissionStatusResponse)
def get_admission_status(db: Session = Depends(get_ledger_db)):
    from app.ledger.validator_config import MAX_SYNC_CLIENTS, SYNC_SOURCE_WEIGHT, THIS_RELAY_DOMAIN

    is_synced = get_consensus_value(db, "is_synced", "true").lower() == "true"
    is_syncing = get_consensus_value(db, "is_syncing", "false").lower() == "true"
    join_mode = get_join_mode(db)
    active_sync_clients = int(get_consensus_value(db, "active_sync_clients", "0"))
    current_block_index = int(get_consensus_value(db, "current_block_index", "0"))

    ready = True
    reason = "ready"

    if not is_synced:
        ready = False
        reason = "relay not fully synced"
    elif is_syncing:
        ready = False
        reason = "relay currently syncing"
    elif join_mode:
        ready = False
        reason = "relay currently in join mode"
    elif active_sync_clients >= MAX_SYNC_CLIENTS:
        ready = False
        reason = "relay at sync client capacity"

    return {
        "relayDomain": THIS_RELAY_DOMAIN,
        "readyForJoin": ready,
        "reason": reason,
        "isSynced": is_synced,
        "isSyncing": is_syncing,
        "joinModeCurrent": join_mode,
        "activeSyncClients": active_sync_clients,
        "maxSyncClients": MAX_SYNC_CLIENTS,
        "syncSourceWeight": SYNC_SOURCE_WEIGHT,
        "currentBlockIndex": current_block_index,
    }

