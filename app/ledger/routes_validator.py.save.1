@router.get("/blocks/head")
def get_ledger_head(db: Session = Depends(get_ledger_db)):
    head = db.query(LedgerBlock).order_by(LedgerBlock.block_index.desc()).first()
    if head is None:
        return {
            "relayDomain": THIS_RELAY_DOMAIN,
            "currentBlockIndex": 0,
            "currentBlockHash": "GENESIS",
        }

    return {
        "relayDomain": THIS_RELAY_DOMAIN,
        "currentBlockIndex": head.block_index,
        "currentBlockHash": head.block_hash,
    }


@router.get("/blocks/{block_index}")
def get_block(block_index: int, db: Session = Depends(get_ledger_db)):
    block = db.query(LedgerBlock).filter(LedgerBlock.block_index == block_index).first()
    if block is None:
        raise HTTPException(status_code=404, detail="block not found")
    return {
        "blockIndex": block.block_index,
        "rawBlock": block.raw_block_json,
    }


@router.get("/blocks")
def get_block_range(
    start: int = Query(..., ge=1),
    end: int = Query(..., ge=1),
    db: Session = Depends(get_ledger_db),
):
    if end < start:
        raise HTTPException(status_code=400, detail="invalid range")

    blocks = (
        db.query(LedgerBlock)
        .filter(LedgerBlock.block_index >= start, LedgerBlock.block_index <= end)
        .order_by(LedgerBlock.block_index.asc())
        .all()
    )

    return {
        "blocks": [
            {
                "blockIndex": block.block_index,
                "rawBlock": block.raw_block_json,
            }
            for block in blocks
        ]
    }


