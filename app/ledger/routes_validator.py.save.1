        db.query(LedgerCommitSignature)
        .filter(LedgerCommitSignature.block_index == block_index)
        .order_by(LedgerCommitSignature.id.asc())
        .all()
    )
    return {
        "blockIndex": block_index,
        "votes": [
            {
                "relayDomain": row.relay_domain,
                "signatureBase64": row.signature_base64,
            }
            for row in rows
        ],
        "voteCount": len(rows),
        "quorumRequired": QUORUM_SIZE,
        "quorumReached": len(rows) >= QUORUM_SIZE,
    }

