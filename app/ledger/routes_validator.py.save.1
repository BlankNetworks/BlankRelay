@router.post("/votes", response_model=LedgerVoteResponse)
def submit_vote(payload: LedgerVoteRequest, db: Session = Depends(get_ledger_db)):
    existing = (
        db.query(LedgerCommitSignature)
        .filter(
            LedgerCommitSignature.block_index == payload.blockIndex,
            LedgerCommitSignature.relay_domain == payload.relayDomain,
        )
        .first()
    )
    if existing is None:
        db.add(
            LedgerCommitSignature(
                block_index=payload.blockIndex,
                relay_domain=payload.relayDomain,
                signature_base64=payload.signatureBase64,
            )
        )
        db.commit()

    return {"success": True, "message": "vote recorded"}


@router.post("/claims/forward", response_model=ForwardClaimResponse)
def forward_claim(payload: ForwardClaimRequest, db: Session = Depends(get_ledger_db)):
    existing = (
        db.query(PendingClaim)
        .filter(PendingClaim.client_claim_hash == "")
        .first()
    )

    from app.ledger.schemas import build_claim_hash
    client_claim_hash = build_claim_hash(
        network_id="blankchat-mainnet-v1",
        blank_id=payload.blankID,
        relay_domain=payload.relayDomain,
        identity_key_base64=payload.identityKeyBase64,
        identity_signing_public_key_base64=payload.identitySigningPublicKeyBase64,
        ownership_signature_base64=payload.ownershipSignatureBase64,
        claimed_at=payload.claimedAt,
        nonce=payload.nonce,
    )

    existing = (
        db.query(PendingClaim)
        .filter(PendingClaim.client_claim_hash == client_claim_hash)
        .first()
    )
    if existing is None:
        db.add(
            PendingClaim(
                blank_id=payload.blankID,
                relay_domain=payload.relayDomain,
                identity_key_base64=payload.identityKeyBase64,
                identity_signing_public_key_base64=payload.identitySigningPublicKeyBase64,
                ownership_signature_base64=payload.ownershipSignatureBase64,
                claimed_at=payload.claimedAt,
                nonce=payload.nonce,
                client_claim_hash=client_claim_hash,
                relay_signature_base64=payload.relaySignatureBase64,
                received_at=payload.claimedAt,
                status="pending_consensus",
            )
        )
        db.commit()

    return {"success": True, "message": "claim forwarded"}

@router.get("/votes/{block_index}")
